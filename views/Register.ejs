<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8" />
    <link rel="stylesheet" href="/css/Registeration.css" />
    <title>Register</title>
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    
</head>
<body>
<div class="Wrapper">
    <div class = "title"> Sign Up Form </div>
        <form action="/register" method="post" onsubmit="validateForm(event)" novalidate>
        <div class="field">
            <input  id="username" type="email" name="username" placeholder=" " required>
            <label>
                 Email Address 
            </label>       
            <i class='bx bx-user-circle'></i>
        </div>
    <div class="field">
        <input id="password" type="password" name="password" placeholder=" " required> 
        <label>
            Password
        </label> 
        
        <i class='bx bx-lock' ></i>
    </div>
<div class="field">
    <input id="confirmPassword" type="password" name="confirmPassword" placeholder=" " required>
    <label>
        Confirm Password
    </label> 
    <i class='bx bx-lock' ></i>
</div>
<span id="ErrorMessage" class="ErrorMessageStyle"></span>
<div class="field">
    <input type="submit" value="Sign up">
</div>
<div class="LoginLink">
    Already have an account? <a href="/login"> Login Here!</a>
</div>
</form>
    </div>
</body>

<script src="/scripts/register.js"></script>
</html>