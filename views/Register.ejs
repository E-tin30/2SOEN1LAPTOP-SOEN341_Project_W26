<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <link rel="stylesheet" href="/css/auth.css" />
    <title>Register</title>
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<body>

<div class="auth-wrapper">
    <div class="auth-box">

        <h2 class="auth-title">Register</h2>

        <form class="auth-form" action="/register" method="post" onsubmit="validateForm(event)" novalidate>

            <div class="auth-field">
                <input id="username" class="auth-input" type="email" name="username" placeholder="Email Address" required>
                <i class="bx bx-user-circle auth-icon"></i>
            </div>

            <div class="auth-field">
                <input id="password" class="auth-input" type="password" name="password" placeholder="Password" required>
                <i class="bx bx-lock auth-icon"></i>
            </div>

            <div class="auth-field">
                <input id="confirmPassword" class="auth-input" type="password" name="confirmPassword" placeholder="Confirm Password" required>
                <i class="bx bx-lock auth-icon"></i>
            </div>

            <span id="ErrorMessage" class="auth-error"></span>

            <button type="submit" class="auth-button">Sign up</button>

            <div class="auth-footer">
                Already have an account? <a class="auth-link" href="/login">Log in</a>
            </div>

        </form>
    </div>
</div>

<script src="/scripts/register.js"></script>
</body>
</html>